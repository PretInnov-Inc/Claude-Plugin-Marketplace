{
  "mcpServers": {
    "codebase-radar": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.py"],
      "env": {
        "RADAR_CONFIG_PATH": "${CLAUDE_PLUGIN_DATA}/config.json",
        "RADAR_STATE_PATH": "${CLAUDE_PLUGIN_DATA}/index-state.json",
        "RADAR_LANCEDB_ROOT": "${CLAUDE_PLUGIN_DATA}/lancedb",
        "RADAR_LOG_PATH": "${CLAUDE_PLUGIN_DATA}/search-log.jsonl"
      }
    }
  }
}
