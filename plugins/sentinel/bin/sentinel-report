#!/usr/bin/env python3
"""
sentinel-report — Print formatted session history as markdown.
Available as a bare command in the Bash tool when sentinel plugin is enabled.
Usage: sentinel-report [--last N] [--markdown]
"""

import json
import os
import sys
from datetime import datetime
from pathlib import Path


def get_data_dir():
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", str(Path(__file__).parent.parent))
    return Path(plugin_root) / "data"


def read_jsonl_tail(path, n):
    if not path.exists():
        return []
    items = []
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if line:
                    try:
                        items.append(json.loads(line))
                    except json.JSONDecodeError:
                        continue
    except Exception:
        return []
    return items[-n:]


def format_ts(ts_str):
    try:
        dt = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        return dt.strftime("%Y-%m-%d %H:%M")
    except Exception:
        return ts_str[:16] if ts_str else "unknown"


def main():
    args = sys.argv[1:]
    last_n = 10
    if "--last" in args:
        idx = args.index("--last")
        if idx + 1 < len(args):
            try:
                last_n = int(args[idx + 1])
            except ValueError:
                pass

    data_dir = get_data_dir()

    sessions = read_jsonl_tail(data_dir / "session-log.jsonl", last_n * 3)
    stops = [s for s in sessions if s.get("event") == "session_stop"][-last_n:]
    learnings = read_jsonl_tail(data_dir / "learnings.jsonl", 20)
    decisions = read_jsonl_tail(data_dir / "decisions.jsonl", 10)
    aps = read_jsonl_tail(data_dir / "anti-patterns.jsonl", 10)

    lines = [
        "# Sentinel Session Report",
        f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}",
        f"Showing last {len(stops)} sessions",
        "",
    ]

    # Session history table
    if stops:
        lines += [
            "## Session History",
            "",
            "| When | Health | Technologies | Learnings | Errors |",
            "|------|--------|-------------|-----------|--------|",
        ]
        for s in stops:
            ts = format_ts(s.get("timestamp", ""))
            health = s.get("health_score", "?")
            tech = ", ".join(s.get("technologies", [])[:3]) or "—"
            nl = s.get("learnings_extracted", 0)
            ec = s.get("error_count", 0)
            health_label = f"**{health}**" if isinstance(health, int) and health < 40 else str(health)
            lines.append(f"| {ts} | {health_label}/100 | {tech} | {nl} | {ec} |")
        lines.append("")
    else:
        lines += ["## Session History", "", "_No sessions recorded yet._", ""]

    # Learnings
    if learnings:
        lines += ["## Accumulated Learnings", ""]
        by_cat: dict = {}
        for l in learnings:
            cat = l.get("category", "general")
            by_cat.setdefault(cat, []).append(l.get("learning", "").strip())
        for cat, items in sorted(by_cat.items()):
            lines.append(f"### {cat.title()}")
            for item in items[-5:]:
                if item:
                    lines.append(f"- {item}")
            lines.append("")

    # Decisions
    if decisions:
        lines += ["## Decision Journal", ""]
        icons = {"success": "✅", "failure": "❌", "pending": "⏳"}
        for d in decisions:
            icon = icons.get(d.get("outcome", "pending"), "⏳")
            decision = d.get("decision", "").strip()
            ctx = d.get("context", "").strip()
            ts = format_ts(d.get("timestamp", ""))
            if decision:
                ctx_str = f" _{ctx}_" if ctx else ""
                lines.append(f"- {icon} {decision}{ctx_str} `{ts}`")
        lines.append("")

    # Anti-patterns
    if aps:
        lines += ["## Anti-Patterns to Avoid", ""]
        for ap in aps:
            pattern = ap.get("pattern", "").strip()
            reason = ap.get("reason", "").strip()
            if pattern:
                reason_str = f" — _{reason}_" if reason else ""
                lines.append(f"- ⚠️ {pattern}{reason_str}")
        lines.append("")

    lines += [
        "---",
        "_Generated by `sentinel-report` | Use `/sentinel:flow-memory` for interactive dashboard_",
    ]

    print("\n".join(lines))


if __name__ == "__main__":
    main()
