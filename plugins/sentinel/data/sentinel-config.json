{
  "churn_threshold": 5,
  "auto_warn_on_risk": true,

  "adaptive_confidence": {
    "enabled": true,
    "base_threshold": 80,
    "min_threshold": 60,
    "max_threshold": 95,
    "decay_rate": 0.05,
    "per_agent": {
      "sentinel-reviewer": 80,
      "bug-hunter": 80,
      "error-auditor": 80,
      "security-scanner": 70,
      "test-analyzer": 80,
      "code-polisher": 85
    }
  },

  "agents": {
    "sentinel-reviewer":  {"enabled": true, "model": "sonnet"},
    "bug-hunter":         {"enabled": true, "model": "opus"},
    "error-auditor":      {"enabled": true, "model": "sonnet"},
    "security-scanner":   {"enabled": true, "model": "opus"},
    "test-analyzer":      {"enabled": true, "model": "haiku"},
    "code-polisher":      {"enabled": true, "model": "haiku"},
    "ai-architect":       {"enabled": true, "model": "opus"},
    "ai-builder":         {"enabled": true, "model": "sonnet"},
    "ai-validator":       {"enabled": true, "model": "haiku"},
    "style-conductor":    {"enabled": true, "model": "haiku"},
    "web-pilot":          {"enabled": true, "model": "sonnet"},
    "a11y-auditor":       {"enabled": true, "model": "haiku"},
    "session-scribe":     {"enabled": true, "model": "haiku"},
    "memory-warden":      {"enabled": true, "model": "sonnet"},
    "ui-architect":       {"enabled": true, "model": "opus"},
    "style-writer":       {"enabled": true, "model": "sonnet"},
    "doc-writer":         {"enabled": true, "model": "sonnet"},
    "content-strategist": {"enabled": true, "model": "opus"},
    "pipeline-builder":   {"enabled": true, "model": "sonnet"},
    "data-profiler":      {"enabled": true, "model": "haiku"},
    "workspace-curator":  {"enabled": true, "model": "sonnet"},
    "design-auditor":     {"enabled": true, "model": "haiku"},
    "sentinel-auditor":   {"enabled": true, "model": "sonnet"},
    "risk-gatekeeper":    {"enabled": true, "model": "opus"}
  },

  "review_modes": {
    "full":     ["sentinel-reviewer", "bug-hunter", "error-auditor", "security-scanner", "test-analyzer", "code-polisher"],
    "quick":    ["sentinel-reviewer", "bug-hunter"],
    "security": ["security-scanner", "error-auditor"],
    "quality":  ["sentinel-reviewer", "code-polisher"],
    "tests":    ["test-analyzer"]
  },

  "risk_gating": {
    "enabled": true,
    "auto_classify": true,
    "tiers": {
      "green": {
        "description": "Trivial changes — no test/config/security/auth files, <30 lines",
        "agents": ["sentinel-reviewer"],
        "require_user_ack": false
      },
      "yellow": {
        "description": "Standard changes — non-critical files, moderate scope",
        "agents": ["sentinel-reviewer", "bug-hunter", "error-auditor"],
        "require_user_ack": false
      },
      "red": {
        "description": "High-risk — security/auth/config/API files or large diffs",
        "agents": ["sentinel-reviewer", "bug-hunter", "error-auditor", "security-scanner", "test-analyzer"],
        "require_user_ack": false
      },
      "critical": {
        "description": "Critical — database migrations, CI/CD, secrets, or multiple high-risk signals",
        "agents": ["sentinel-reviewer", "bug-hunter", "error-auditor", "security-scanner", "test-analyzer", "code-polisher"],
        "require_user_ack": true,
        "escalate_to": "risk-gatekeeper"
      }
    }
  },

  "output_style": {
    "active": "focused",
    "available": ["focused", "learning", "verbose"],
    "inject_on_session_start": true
  },

  "memory": {
    "enabled": true,
    "max_learnings_in_context": 15,
    "max_decisions_in_context": 5,
    "max_anti_patterns_in_context": 8,
    "session_health_warn_below": 40,
    "auto_extract_learnings": true,
    "typed_store": {
      "enabled": true,
      "path": ".sentinel/learnings/",
      "categories": [
        "build-errors",
        "plugin-design",
        "skill-authoring",
        "security",
        "workflow",
        "testing",
        "architecture",
        "general"
      ],
      "refresh_interval_days": 14,
      "autofix_safe_actions": true,
      "grep_first_retrieval": true,
      "max_files_to_full_read": 10
    },
    "lineage": {
      "enabled": true,
      "path": ".sentinel/lineage/",
      "rollover_trigger": "graduated",
      "stages": {
        "warn_at_pct": 75,
        "offer_at_pct": 85,
        "hard_fork_at_pct": 95
      },
      "respect_busy_state": true,
      "team_mode": "per_user"
    }
  },

  "activation": {
    "hard_gates_enabled": true,
    "hard_hooks": {
      "security_patterns": "block",
      "tdd_enforcement": "off",
      "blueprint_gate": "warn",
      "destructive_commands": "block"
    }
  },

  "compression": {
    "enabled": true,
    "threshold_chars": 3000,
    "debounce_every_n_calls": 3,
    "log_savings": true,
    "savings_log": "data/compression.jsonl"
  },

  "prompt_routing": {
    "enabled": true,
    "prefix": ">",
    "routes": {
      "review":    "sentinel-status --trigger review",
      "quick":     "sentinel-status --trigger quick",
      "security":  "sentinel-status --trigger security",
      "rollover":  "sentinel-status --trigger rollover",
      "doctor":    "sentinel-doctor",
      "refresh":   "sentinel-refresh --auto",
      "resume":    "sentinel-status --trigger resume"
    }
  },

  "design_system": {
    "enabled": true,
    "path": ".sentinel/design-system.md",
    "auto_load_on_session_start": true,
    "drift_detection": true,
    "drift_check_on_ui_edit": true,
    "ui_extensions": ["tsx", "jsx", "vue", "svelte"]
  },

  "ai_forge": {
    "research_before_build": true,
    "always_blueprint_first": true,
    "validate_after_generate": true,
    "hard_gate_before_build": true
  },

  "browser": {
    "default_viewport": "1280x720",
    "a11y_wcag_level": "AA",
    "screenshot_on_fail": true
  },

  "infra": {
    "dag_test_before_deploy": true,
    "lineage_tracking": true
  }
}
